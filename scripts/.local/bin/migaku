#!/bin/bash

# =============================================================================
# HEVC 10-bit → h.264 8-bit Converter for Migaku (Arch Linux)
# Only processes .mkv files with HEVC video
# Preserves all audio, subtitles, chapters, attachments
# =============================================================================

set -euo pipefail

# === CONFIGURATION ===
DRY_RUN=false          # Set to true to see what would be converted
MAKE_BACKUP=true       # Set to false to skip backup
BACKUP_DIR="hevc_backup_$(date +%Y%m%d_%H%M%S)"
CRF=21                 # 18–23: visually lossless, 21 is excellent
PRESET="slow"          # slower = better compression, options: ultrafast, veryfast, ..., veryslow

# === COLORS ===
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# === CHECK DEPENDENCIES ===
for cmd in ffmpeg ffprobe; do
    command -v "$cmd" &>/dev/null || { echo -e "${RED}Error: $cmd not found. Install ffmpeg.${NC}"; exit 1; }
done

# === CREATE BACKUP ===
if [ "$MAKE_BACKUP" = true ]; then
    echo -e "${YELLOW}Creating backup in: $BACKUP_DIR${NC}"
    mkdir -p "$BACKUP_DIR"
    cp -v *.mkv "$BACKUP_DIR/" 2>/dev/null || true
fi

# === MAIN LOOP ===
echo -e "${GREEN}Scanning for HEVC 10-bit .mkv files...${NC}\n"

for f in *.mkv; do
    [[ -f "$f" ]] || continue

    # Get video codec and profile
    video_info=$(ffprobe -v error -select_streams v:0 -show_entries stream=codec_name,profile -of csv=p=0 "$f" 2>/dev/null || echo "")

    if [[ "$video_info" == *"hevc"* ]] && [[ "$video_info" == *"Main 10"* ]] || [[ "$video_info" == *"hevc"* && ! "$video_info" == *"Main"* ]]; then
        echo -e "${YELLOW}→ Converting: $f${NC}"
        echo "   Codec: $video_info"

        if [ "$DRY_RUN" = true ]; then
            echo -e "   ${GREEN}[DRY RUN] Would run: ffmpeg -i \"$f\" -map 0 -c:v libx264 -vf format=yuv420p -crf $CRF -preset $PRESET -c:a copy -c:s copy \"FIXED_$f\" && mv \"FIXED_$f\" \"$f\"${NC}\n"
            continue
        fi

        # Convert
        if ffmpeg -i "$f" -map 0 \
            -c:v libx264 -vf format=yuv420p -crf "$CRF" -preset "$PRESET" \
            -c:a copy -c:s copy -c:t copy \
            "FIXED_$f" && mv -f "FIXED_$f" "$f"; then
            echo -e "   ${GREEN}Successfully converted and replaced: $f${NC}\n"
        else
            echo -e "   ${RED}Failed to convert: $f${NC}\n" >&2
            [[ -f "FIXED_$f" ]] && rm -f "FIXED_$f"
        fi
    else
        echo -e "${GREEN}Skipping (not 10-bit HEVC): $f${NC} ($video_info)"
    fi
done

echo -e "${GREEN}All done! Migaku should now play all files.${NC}"
